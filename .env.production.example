# QueenLib Production Environment Configuration
# ============================================
# IMPORTANT: 
# 1. Copy this file to .env.production
# 2. Update ALL values with your production settings
# 3. Keep this file SECURE - never commit to git
# 4. Set file permissions: chmod 600 .env.production
# 5. Only visible to owner/root

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Environment type (production, staging, development)
APP_ENV=production

# Enable/disable debug mode (ALWAYS false in production)
APP_DEBUG=false

# Full application URL
APP_URL=https://yourdomain.com

# Timezone for timestamps and cron jobs
APP_TIMEZONE=America/New_York

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Database host
# For local: localhost
# For remote: db.example.com or IP address
DB_HOST=localhost

# Database port (standard MySQL: 3306)
DB_PORT=3306

# Database name
# Must match the created database
DB_NAME=queenlib_prod

# Database username
# Should NOT be root
# Create dedicated user with minimal permissions
DB_USER=queenlib_user

# Database password
# IMPORTANT: Use strong password (30+ characters)
# Mix uppercase, lowercase, numbers, and symbols
# Example: Tr0p!cal$Sunset#2026*Migration
DB_PASS=CHANGE_ME_TO_STRONG_PASSWORD

# Database SSL (optional, for secured connections)
DB_SSL=false

# ============================================
# EMAIL / SMTP CONFIGURATION
# ============================================

# Email sending method (smtp, sendmail, or api)
MAIL_DRIVER=smtp

# SMTP Host
# Gmail: smtp.gmail.com
# SendGrid: smtp.sendgrid.net
# Mailgun: smtp.mailgun.org
# Custom: your.mail.server.com
MAIL_HOST=smtp.gmail.com

# SMTP Port
# TLS: 587
# SSL: 465
# Unencrypted: 25
MAIL_PORT=587

# SMTP Username / Email Address
# Gmail: your-email@gmail.com
# SendGrid: apikey (literal string)
# Mailgun: postmaster@yourdomain.com
MAIL_USER=your-email@gmail.com

# SMTP Password / API Key
# Gmail: App Password (16 chars with spaces removed)
# SendGrid: Full API key starting with SG.
# Mailgun: SMTP password
MAIL_PASS=xxxx xxxx xxxx xxxx

# Email encryption type
# Options: tls, ssl, or none
MAIL_ENCRYPTION=tls

# "From" email address for system emails
# Best practice: noreply@yourdomain.com
MAIL_FROM=noreply@yourdomain.com

# "From" name for system emails
MAIL_FROM_NAME=QueenLib

# Reply-to address (optional)
MAIL_REPLY_TO=support@yourdomain.com

# ============================================
# SESSION CONFIGURATION
# ============================================

# Session timeout in seconds (1 hour = 3600)
SESSION_TIMEOUT=3600

# Session name
SESSION_NAME=queenlib_session

# Session save path (default: /tmp, but use custom for security)
SESSION_PATH=/var/lib/php/sessions/queenlib

# ============================================
# TOKEN & SECURITY CONFIGURATION
# ============================================

# Email verification token expiration (24 hours = 86400 seconds)
TOKEN_EXPIRY=86400

# Password reset token expiration (1 hour = 3600 seconds)
RESET_TOKEN_EXPIRY=3600

# Bcrypt password hashing cost (10-12 recommended)
BCRYPT_COST=12

# Application secret key for hashing
# Generate: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=your-32-byte-hex-string-here

# ============================================
# RATE LIMITING CONFIGURATION
# ============================================

# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Number of requests allowed
RATE_LIMIT_REQUESTS=100

# Time window in seconds (60 = 1 minute)
RATE_LIMIT_WINDOW=60

# Login attempt limits
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_TIME=900

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log file path (must be writable by www-data)
LOG_PATH=/var/log/queenlib/

# Log level
# Options: debug, info, notice, warning, error, critical, alert, emergency
LOG_LEVEL=warning

# Log to file (true/false)
LOG_FILE=true

# Log to syslog (true/false)
LOG_SYSLOG=true

# ============================================
# MONITORING & ALERTING
# ============================================

# Enable application monitoring
MONITORING_ENABLED=true

# Alert email address for critical errors
ALERT_EMAIL=devops@yourdomain.com

# Application performance monitoring (APM)
# Optional: Set to your APM service endpoint
APM_ENABLED=false
APM_ENDPOINT=https://apm.example.com

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================

# Maximum upload file size (in MB)
MAX_UPLOAD_SIZE=10

# Allowed file extensions (comma-separated)
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# Upload directory path
UPLOAD_PATH=/var/www/queenlib/uploads

# ============================================
# CACHE CONFIGURATION
# ============================================

# Cache driver
# Options: file, redis, memcached
CACHE_DRIVER=file

# Cache time-to-live in seconds
CACHE_TTL=3600

# Redis configuration (if using Redis cache)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ============================================
# 3RD PARTY SERVICES (OPTIONAL)
# ============================================

# Google Analytics
GOOGLE_ANALYTICS_ID=

# Sentry error tracking
SENTRY_DSN=

# Slack webhook for notifications
SLACK_WEBHOOK_URL=

# ============================================
# BACKUP CONFIGURATION
# ============================================

# Enable automated backups
BACKUP_ENABLED=true

# Backup frequency (daily, weekly, monthly)
BACKUP_FREQUENCY=daily

# Backup retention days
BACKUP_RETENTION_DAYS=30

# S3 backup destination (optional)
# S3_ENABLED=false
# S3_KEY=
# S3_SECRET=
# S3_BUCKET=

# ============================================
# NOTES FOR PRODUCTION SETUP
# ============================================
# 
# 1. DATABASE SECURITY:
#    - Use dedicated database user (NOT root)
#    - Set minimal required permissions
#    - Use strong password with 30+ characters
#    - Enable MySQL user password encryption
#    - Use separate database for app isolation
#
# 2. EMAIL SERVICE:
#    - Gmail: Use App Passwords (not account password)
#    - SendGrid/Mailgun: Use generated API keys
#    - Test sending before deploying
#    - Monitor delivery rates and bounces
#
# 3. FILE PERMISSIONS:
#    - chmod 600 .env.production
#    - chmod 700 upload directories
#    - chmod 755 application directories
#    - chown www-data: for web accessible files
#
# 4. SECURITY BEST PRACTICES:
#    - Never share this file
#    - Rotate passwords quarterly
#    - Use HTTPS everywhere
#    - Enable firewall on database
#    - Regular security audits
#    - Monitor access logs
#
# 5. BACKUP & RECOVERY:
#    - Test restore procedures regularly
#    - Store backups off-site
#    - Encrypt backup files
#    - Document recovery procedures
#    - Monitor backup success
#
# 6. MONITORING:
#    - Setup error tracking (Sentry)
#    - Monitor application performance
#    - Alert on critical errors
#    - Track uptime metrics
#    - Regular log review
