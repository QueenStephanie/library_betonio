{
  "info": {
    "name": "Library Betonio - Authentication API",
    "description": "Complete collection for testing Library Betonio backend API endpoints",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost/library_betonio",
      "type": "string"
    },
    {
      "key": "email",
      "value": "test@example.com",
      "type": "string"
    },
    {
      "key": "otp_code",
      "value": "123456",
      "type": "string"
    },
    {
      "key": "reset_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Register User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "    pm.environment.set('user_id', pm.response.json().user_id);",
              "    pm.environment.set('email', pm.response.json().email);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"password\": \"SecurePass123!\",\n    \"password_confirm\": \"SecurePass123!\"\n}"
          }
        },
        "url": {
          "raw": "{{base_url}}/backend/api/register.php",
          "protocol": "http",
          "host": ["localhost"],
          "path": ["library_betonio", "backend", "api", "register.php"]
        }
      },
      "response": []
    },
    {
      "name": "2. Request OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"john.doe@example.com\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/backend/api/request-otp.php",
          "protocol": "http",
          "host": ["localhost"],
          "path": ["library_betonio", "backend", "api", "request-otp.php"]
        }
      },
      "response": []
    },
    {
      "name": "3. Verify OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"john.doe@example.com\",\n    \"otp_code\": \"{{otp_code}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/backend/api/verify-otp.php",
          "protocol": "http",
          "host": ["localhost"],
          "path": ["library_betonio", "backend", "api", "verify-otp.php"]
        }
      },
      "response": []
    },
    {
      "name": "4. Resend OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"john.doe@example.com\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/backend/api/resend-otp.php",
          "protocol": "http",
          "host": ["localhost"],
          "path": ["library_betonio", "backend", "api", "resend-otp.php"]
        }
      },
      "response": []
    },
    {
      "name": "5. Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"john.doe@example.com\",\n    \"password\": \"SecurePass123!\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/backend/api/login.php",
          "protocol": "http",
          "host": ["localhost"],
          "path": ["library_betonio", "backend", "api", "login.php"]
        }
      },
      "response": []
    },
    {
      "name": "6. Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "{{base_url}}/backend/api/logout.php",
          "protocol": "http",
          "host": ["localhost"],
          "path": ["library_betonio", "backend", "api", "logout.php"]
        }
      },
      "response": []
    },
    {
      "name": "7. Forgot Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"john.doe@example.com\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/backend/api/forgot-password.php",
          "protocol": "http",
          "host": ["localhost"],
          "path": ["library_betonio", "backend", "api", "forgot-password.php"]
        }
      },
      "response": []
    },
    {
      "name": "8. Verify Reset Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"john.doe@example.com\",\n    \"reset_token\": \"{{reset_token}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/backend/api/verify-reset-token.php",
          "protocol": "http",
          "host": ["localhost"],
          "path": ["library_betonio", "backend", "api", "verify-reset-token.php"]
        }
      },
      "response": []
    },
    {
      "name": "9. Reset Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"john.doe@example.com\",\n    \"reset_token\": \"{{reset_token}}\",\n    \"new_password\": \"NewSecurePass456!\",\n    \"confirm_password\": \"NewSecurePass456!\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/backend/api/reset-password.php",
          "protocol": "http",
          "host": ["localhost"],
          "path": ["library_betonio", "backend", "api", "reset-password.php"]
        }
      },
      "response": []
    }
  ]
}
