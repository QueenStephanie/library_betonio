Options -Indexes

<IfModule mod_rewrite.c>
RewriteEngine On

# HTTPS redirect for Infinity Free (SSL is automatic)
RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1|\[::1\])(?::\d+)?$ [NC]
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Block hidden files (except .well-known)
RewriteRule (^|/)\.(?!well-known/) - [F,L]

# Block sensitive directories
RewriteRule ^(?:includes|docs|_legacy)/ - [F,L]
RewriteRule ^backend/(?:config|classes|mail|vendor)/ - [F,L]
RewriteRule ^backend/(?:migrations|mcp)/ - [F,L]
RewriteRule ^app/ - [F,L]

# Block setup and maintenance entry points outside localhost
RewriteCond %{REMOTE_ADDR} !^(127\.0\.0\.1|::1|::ffff:127\.0\.0\.1)$
RewriteRule ^(?:init-database\.php|backend/setup-db\.php)$ - [F,L]

# Deny direct access to configuration files
RewriteRule ^\.env(?:\.production)?$ - [F,L]
RewriteRule ^\.env\.example$ - [F,L]
</IfModule>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set X-Frame-Options "SAMEORIGIN"

    <FilesMatch "\.(?:css|js|jpg|jpeg|png|gif|svg|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000"
    </FilesMatch>
</IfModule>

<IfModule mod_authz_core.c>
    <FilesMatch "^(?:\.env|composer\.(?:json|lock)|phpunit\.xml|README\.md|CHANGELOG\.md)$">
        Require all denied
    </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>
