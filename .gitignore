dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# Environment - CRITICAL: Never commit sensitive data
# Ignore actual .env files (contain real secrets)
.env
.env.local
.env.*.local
# Ignore production/staging/dev env files (contain real secrets)
.env.production
.env.staging
.env.development
# But keep .env.example and .env.*.example (template files without secrets)
# *.env.example is NOT listed here so template files are committed
# Backup files
*.bak
*.backup
*~

# OS files
.DS_Store
*.exe
*.dll
*.pyd
Thumbs.db

# Testing
.coverage
htmlcov/
*.log

# Log files
logs/
*.log

# Temporary files
tmp/
temp/
cache/
*.tmp
.playwright-mcp/
.tmp_*

# IDE specific
.vscode/
.idea/
.vim/

# Old/legacy code
_legacy/
old_backup/

# Test configuration and reports (keep test plans, exclude test execution results)
testsprite_tests/results/
testsprite_tests/.cache/

# PHP/composer artifacts
vendor/
backend/vendor/
*.cache
